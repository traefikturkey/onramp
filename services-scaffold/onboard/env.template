###############################################
# Onboard Configuration
#
# Generated from services-scaffold/onboard/env.template
# To regenerate: make scaffold-build onboard
###############################################
# https://github.com/traefikturkey/onboard

# Docker image tag
ONBOARD_DOCKER_TAG=${ONBOARD_DOCKER_TAG:-latest}

# Container configuration
ONBOARD_CONTAINER_NAME=${ONBOARD_CONTAINER_NAME:-onboard}
ONBOARD_RESTART=${ONBOARD_RESTART:-unless-stopped}
ONBOARD_MEM_LIMIT=${ONBOARD_MEM_LIMIT:-1g}

# Page loading timeout (in seconds, default 10 minutes)
ONBOARD_PAGE_TIMEOUT=${ONBOARD_PAGE_TIMEOUT:-600}

# Ollama integration - URL to the ollama service (set in ollama.env or .env.external)
# OLLAMA_URL=${OLLAMA_URL:-http://ollama:11434}

# Traefik routing
ONBOARD_TRAEFIK_ENABLE=${ONBOARD_TRAEFIK_ENABLE:-true}

# Auto-updates and monitoring
ONBOARD_WATCHTOWER_ENABLE=${ONBOARD_WATCHTOWER_ENABLE:-true}
ONBOARD_AUTOHEAL=${ONBOARD_AUTOHEAL:-true}
