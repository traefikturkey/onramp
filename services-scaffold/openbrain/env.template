###############################################
# OpenBrain — Memory Layer for AI Agents
#
# Generated from services-scaffold/openbrain/env.template
# To regenerate: make scaffold-build openbrain
###############################################

# Container settings
OPENBRAIN_IMAGE_TAG=${OPENBRAIN_IMAGE_TAG:-latest}
OPENBRAIN_CONTAINER_NAME=${OPENBRAIN_CONTAINER_NAME:-openbrain}
OPENBRAIN_DB_CONTAINER_NAME=${OPENBRAIN_DB_CONTAINER_NAME:-openbrain-db}
OPENBRAIN_RESTART=${OPENBRAIN_RESTART:-unless-stopped}
OPENBRAIN_PGVECTOR_TAG=${OPENBRAIN_PGVECTOR_TAG:-pg16}

# Traefik / hostname
OPENBRAIN_HOST_NAME=${OPENBRAIN_HOST_NAME:-openbrain}
OPENBRAIN_TRAEFIK_ENABLED=${OPENBRAIN_TRAEFIK_ENABLED:-true}
OPENBRAIN_WATCHTOWER_ENABLED=${OPENBRAIN_WATCHTOWER_ENABLED:-true}
OPENBRAIN_AUTOHEAL_ENABLED=${OPENBRAIN_AUTOHEAL_ENABLED:-true}
OPENBRAIN_DB_WATCHTOWER_ENABLED=${OPENBRAIN_DB_WATCHTOWER_ENABLED:-false}
OPENBRAIN_DB_AUTOHEAL_ENABLED=${OPENBRAIN_DB_AUTOHEAL_ENABLED:-true}

# MCP auth — auto-generated if blank (clients pass as: Authorization: Bearer <key>)
OPENBRAIN_MCP_ACCESS_KEY=${OPENBRAIN_MCP_ACCESS_KEY}

# PostgreSQL — dedicated container (NOT the shared Onramp postgres)
OPENBRAIN_DB_NAME=${OPENBRAIN_DB_NAME:-openbrain}
OPENBRAIN_DB_USER=${OPENBRAIN_DB_USER:-openbrain}
OPENBRAIN_DB_PASSWORD=${OPENBRAIN_DB_PASSWORD}
OPENBRAIN_DB_HOST=${OPENBRAIN_DB_HOST:-openbrain-db}
OPENBRAIN_DB_PORT=${OPENBRAIN_DB_PORT:-5432}

# Embedding provider: ollama (default), openai, openrouter
OPENBRAIN_EMBEDDING_PROVIDER=${OPENBRAIN_EMBEDDING_PROVIDER:-ollama}
OPENBRAIN_EMBEDDING_MODEL=${OPENBRAIN_EMBEDDING_MODEL:-nomic-embed-text}
OPENBRAIN_EMBEDDING_DIMENSIONS=${OPENBRAIN_EMBEDDING_DIMENSIONS:-768}

# Ollama (default — assumes Onramp's ollama service is enabled on the same network)
OPENBRAIN_OLLAMA_BASE_URL=${OPENBRAIN_OLLAMA_BASE_URL:-http://ollama:11434}

# OpenAI (optional — used when OPENBRAIN_EMBEDDING_PROVIDER=openai)
OPENBRAIN_OPENAI_API_KEY=${OPENBRAIN_OPENAI_API_KEY:-}
OPENBRAIN_OPENAI_MODEL=${OPENBRAIN_OPENAI_MODEL:-text-embedding-3-small}

# OpenRouter (optional — used when OPENBRAIN_EMBEDDING_PROVIDER=openrouter)
OPENBRAIN_OPENROUTER_API_KEY=${OPENBRAIN_OPENROUTER_API_KEY:-}

# Metadata extraction LLM (optional — enriches tags/topics on capture)
OPENBRAIN_METADATA_LLM_PROVIDER=${OPENBRAIN_METADATA_LLM_PROVIDER:-ollama}
OPENBRAIN_METADATA_LLM_MODEL=${OPENBRAIN_METADATA_LLM_MODEL:-qwen2.5-coder:14b}

# Search tuning
OPENBRAIN_HYBRID_WEIGHT=${OPENBRAIN_HYBRID_WEIGHT:-0.3}
OPENBRAIN_DEDUP_THRESHOLD=${OPENBRAIN_DEDUP_THRESHOLD:-0.92}
OPENBRAIN_MERGE_LOWER_THRESHOLD=${OPENBRAIN_MERGE_LOWER_THRESHOLD:-0.70}

# Memory decay (0 disables consolidation thread)
OPENBRAIN_DECAY_LAMBDA=${OPENBRAIN_DECAY_LAMBDA:-0.005}
OPENBRAIN_CONSOLIDATION_INTERVAL=${OPENBRAIN_CONSOLIDATION_INTERVAL:-0}

# Write gate
OPENBRAIN_HEADLINE_MAX_WORDS=${OPENBRAIN_HEADLINE_MAX_WORDS:-15}
OPENBRAIN_BODY_MAX_WORDS=${OPENBRAIN_BODY_MAX_WORDS:-400}

# Boot payload caps
OPENBRAIN_BOOT_TOKEN_CAP=${OPENBRAIN_BOOT_TOKEN_CAP:-2000}
OPENBRAIN_BOOT_BLOCKER_CAP=${OPENBRAIN_BOOT_BLOCKER_CAP:-5}
OPENBRAIN_BOOT_PATTERN_CAP=${OPENBRAIN_BOOT_PATTERN_CAP:-5}
OPENBRAIN_BOOT_TASK_CAP=${OPENBRAIN_BOOT_TASK_CAP:-20}
