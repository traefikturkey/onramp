################################################
#
# OnRamp External Services Configuration
#
# Settings for external services proxied through Traefik
# Edit this file with: make edit-env-external
#
# Uncomment and configure the services you want to proxy.
# Then enable them with: make enable-external <service>
#
################################################

# Proxmox - supports up to 10 instances (proxmox, proxmox2 ... proxmox10)
# Each instance needs a _HOST_NAME (subdomain) and _ADDRESS (IP).
# Additional instances activate automatically when their _ADDRESS is set.
# Copy/paste and increment the number to add more (up to 10).
#PROXMOX_HOST_NAME=proxmox
#PROXMOX_ADDRESS=192.168.1.50
#PROXMOX2_HOST_NAME=proxmox2
#PROXMOX2_ADDRESS=192.168.1.51
#PROXMOX3_HOST_NAME=proxmox3
#PROXMOX3_ADDRESS=192.168.1.52
#PROXMOX4_HOST_NAME=proxmox4
#PROXMOX4_ADDRESS=192.168.1.53

# Home Assistant
#HOMEASSISTANT_IP=
#HOMEASSISTANT_PORT=8123

# iDRAC
#IDRAC_IP=
