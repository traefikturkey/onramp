################################################
#
# OnRamp NFS Configuration
#
# Settings for NFS-mounted media directories
# Edit this file with: make edit-env-nfs
#
################################################

# required: NFS_SERVER
# NFS server hostname or IP (required for NFS mounts)
NFS_SERVER=

# Base NFS media path
NFS_MEDIA_PATH=/mnt/media

# Common media paths (derived from NFS_MEDIA_PATH)
NFS_MOVIES_PATH=${NFS_MEDIA_PATH}/movies
NFS_SHOWS_PATH=${NFS_MEDIA_PATH}/shows
NFS_MUSIC_PATH=${NFS_MEDIA_PATH}/music
NFS_DOWNLOADS_PATH=${NFS_MEDIA_PATH}/downloads

# Specialized media paths
NFS_BOOKS_PATH=${NFS_MEDIA_PATH}/audiobooks
NFS_COMICS_PATH=${NFS_MEDIA_PATH}/comics
NFS_PODCASTS_PATH=${NFS_MEDIA_PATH}/podcasts
NFS_YT_PATH=${NFS_MEDIA_PATH}/ytd
NFS_SYNC_PATH=${NFS_MEDIA_PATH}/sync

# Application-specific paths
NFS_PHOTOPRISM_PATH=${NFS_MEDIA_PATH}/photoprism
NFS_NEXTCLOUD_PATH=${NFS_MEDIA_PATH}/nextcloud
NFS_IMMICH_DATA_PATH=${NFS_MEDIA_PATH}/immich
NFS_LIBREPHOTOS_DATA_PATH=${NFS_MEDIA_PATH}/librephotos
NFS_LIBREPHOTOS_SCAN_PATH=${NFS_MEDIA_PATH}/librephotos/scan
NFS_MINIO_PATH=${NFS_MEDIA_PATH}/minio
NFS_KOMGA_PATH=${NFS_MEDIA_PATH}/comics

# NFS mount options
NFS_MOUNT_OPTIONS=soft,rw,nfsvers=4

# NFS backup location for OnRamp config backups
# Used by: make create-nfs-backup, make restore-nfs-backup
NFS_BACKUP_PATH=${NFS_MEDIA_PATH}/backups
